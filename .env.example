# =============================================
# Eclipse Frontend 환경변수 가이드
# cp .env.example .env 후 값을 채워주세요
# =============================================

# Backend API
# ledger-app (청약, 리턴플랜, 계좌, 증권주문)
VITE_LEDGER_URL=http://localhost:8080

# service-app (IPO 탐색, 증권조회, AI 분석, 홈)
VITE_SERVICE_URL=http://localhost:8081

# Firebase FCM (푸시 알림)
# console.firebase.google.com → 프로젝트 생성 → 웹 앱 추가 → SDK 설정에서 복사
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Cloud Messaging 탭 → 웹 푸시 인증서 → 키 쌍 생성
VITE_FIREBASE_VAPID_KEY=
